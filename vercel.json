{
  "cleanUrls": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/wasm/index.html"
    }
  ],
  "headers": [
    {
      "source": "/wasm/(.*)\\.wasm",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/wasm"
        },
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}